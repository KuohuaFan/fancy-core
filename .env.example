# 資料庫
DATABASE_URL="postgresql://user:pass@localhost:5432/pinglex?schema=public"

# Auth.js
AUTH_SECRET="用 openssl rand -base64 32 產生"

# Fancy AI（事務所自帶金鑰，僅存於伺服器）
# 預設供應商：anthropic、google、openai 或 mistral。若未設定，依下列已填金鑰自動選擇。
LLM_PROVIDER="anthropic"

# Claude（Anthropic）
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Gemini（Google）
GOOGLE_API_KEY=""
GOOGLE_MODEL="gemini-2.5-flash"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Mistral AI
MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-large-latest"

# 物件儲存（卷證文件）
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Google 行事曆（雙向同步）
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 既有法律資料源（查法律/查卷證）——裁判家 lawRef MCP 閘道
LAWREF_MCP_URL="https://<your-lawref-mcp-endpoint>"

# 示範資料的預設密碼（npm run db:seed 用）；未設定則為 demo1234
SEED_PASSWORD=""
